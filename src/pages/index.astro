>
  <Hero locale="pt" />
  <About locale="pt" />
  <Accommodation locale="pt" />
  <Activities locale="pt" />
  <Amenities locale="pt" />
  <Location locale="pt" />
  <Retreats locale="pt" />
  <Heritage locale="pt" />
  <Testimonials locale="pt" />
  <Booking locale="pt" />
</Base>
