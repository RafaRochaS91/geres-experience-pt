---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Accommodation from '../components/Accommodation.astro';
import Activities from '../components/Activities.astro';
import Amenities from '../components/Amenities.astro';
import Location from '../components/Location.astro';
import Retreats from '../components/Retreats.astro';
import Heritage from '../components/Heritage.astro';
import Testimonials from '../components/Testimonials.astro';
import Booking from '../components/Booking.astro';
---

<Base
  locale="pt"
