---
import type { Locale } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);

const stats = [
  { num: '24', label: t('retreats.people') },
  { num: '6',  label: t('retreats.houses') },
  { num: '3',  label: t('retreats.types') },
  { num: '∞',  label: t('retreats.nature') },
];

const features = locale === 'pt'
  ? [
      { icon: '🧘', title: 'Locais para prática', desc: 'Salas amplas e luminosas para meditação, yoga e mindfulness. Áreas ao ar livre únicas.' },
      { icon: '🍽️', title: 'Espaços de refeições', desc: 'Catering saudável e personalizado com opções adaptadas a dietas específicas.' },
      { icon: '🌿', title: 'Actividades de team building', desc: 'Caminhadas guiadas, experiências na natureza e programas de bem-estar personalizados.' },
    ]
  : [
      { icon: '🧘', title: 'Practice spaces', desc: 'Bright, spacious rooms for meditation, yoga and mindfulness. Unique outdoor areas.' },
      { icon: '🍽️', title: 'Dining spaces', desc: 'Healthy, personalised catering with options adapted to specific diets.' },
      { icon: '🌿', title: 'Team building activities', desc: 'Guided hikes, nature experiences and personalised wellness programmes.' },
    ];
---

<section id="retreats" class="py-24 bg-[var(--color-brand-dark)] relative overflow-hidden">
  <div class="absolute inset-0 opacity-10" style="background-image:url('/images/retreats-bg.jpg'); background-size:cover; background-position:center;" aria-hidden="true"></div>

  <div class="container relative z-10">
    <p class="section-label text-[var(--color-highlight)]">{t('retreats.label')}</p>
    <h2 class="section-title text-[var(--color-surface)]" set:html={t('retreats.title')} />

    <div class="grid md:grid-cols-2 gap-16 mt-10">
      <div>
        <p class="text-[var(--color-surface)]/80 leading-relaxed mb-8" set:html={t('retreats.intro')} />

        <div class="grid grid-cols-4 gap-4 mb-8">
          {stats.map(s => (
            <div class="text-center">
              <p class="font-serif text-3xl font-semibold text-[var(--color-highlight)]">{s.num}</p>
              <p class="text-[0.65rem] uppercase tracking-widest text-[var(--color-surface)]/60 mt-1">{s.label}</p>
            </div>
          ))}
        </div>

        <a href="#booking" class="btn-primary">{t('retreats.cta')}</a>
      </div>

      <div class="space-y-6">
        {features.map(f => (
          <div class="flex gap-4">
            <span class="text-2xl flex-shrink-0">{f.icon}</span>
            <div>
              <h4 class="font-sans font-bold text-sm text-[var(--color-highlight)] mb-1">{f.title}</h4>
              <p class="text-[var(--color-surface)]/70 text-sm leading-relaxed">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
