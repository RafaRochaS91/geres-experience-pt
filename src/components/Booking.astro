---
import type { Locale } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);

const policies = [
  { label: t('booking.checkin'),  value: t('booking.checkin.time') },
  { label: t('booking.checkout'), value: t('booking.checkout.time') },
  { label: t('booking.min_stay'), value: t('booking.min_stay.value') },
  { label: t('booking.pets'),     value: t('booking.pets.value') },
];
---

<section id="booking" class="py-24 bg-[var(--color-brand-dark)]">
  <div class="container">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <div>
        <p class="section-label text-[var(--color-highlight)]">{t('booking.label')}</p>
        <h2 class="section-title text-[var(--color-surface)]" set:html={t('booking.title')} />
        <p class="text-[var(--color-surface)]/75 leading-relaxed mb-8">{t('booking.intro')}</p>

        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href="https://www.booking.com/hotel/pt/aldeia-turistica-de-louredo.pt-pt.html"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            {t('booking.cta.booking')}
          </a>
          <a href="tel:+351917722184" class="btn-outline">{t('booking.cta.phone')}</a>
        </div>
      </div>

      <div class="space-y-4">
        {policies.map(p => (
          <div class="flex justify-between items-center border-b border-white/10 pb-3">
            <span class="text-[0.7rem] font-bold uppercase tracking-widest text-[var(--color-surface)]/60">{p.label}</span>
            <span class="text-sm text-[var(--color-surface)]/90">{p.value}</span>
          </div>
        ))}
        <div class="pt-2">
          <p class="text-[var(--color-surface)]/60 text-xs">
            {locale === 'pt'
              ? 'Contacte-nos também por e-mail para grupos e estadias longas.'
              : 'Also contact us by email for groups and extended stays.'}
          </p>
          <span
            class="email-protected text-sm text-[var(--color-highlight)] mt-2 inline-block"
            data-email="YWxkZWlhZGVsb3VyZWRvQGdlcmVzZXhwZXJpZW5jZS5wdA=="
          >&#8203;</span>
        </div>
      </div>
    </div>
  </div>
</section>
